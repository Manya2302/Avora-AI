# ── Django ─────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-django-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://svuser:svpass123@postgres:5432/securevault

# ── Redis / Celery ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── MinIO ──────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=False
MINIO_BUCKET_NAME=securevault-documents

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=securevault_documents

# ── Ollama (Orivo AI) ──────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Encryption ─────────────────────────────────────────────────
RSA_KEY_SIZE=4096
CHUNK_SIZE_MB=10
ZSTD_COMPRESSION_LEVEL=9

# ── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Admin ──────────────────────────────────────────────────────
ADMIN_URL_PREFIX=securevault-admin
